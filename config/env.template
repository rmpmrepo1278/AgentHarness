# =============================================================================
# AgentHarness Environment Configuration
# Copy to your AgentHarness data dir as .env and fill in your values
# =============================================================================

# --- Groq API (emergency escalation, capped at 200 req/day) ---
GROQ_API_KEY=
GROQ_DAILY_LIMIT=200

# --- Portainer ---
PORTAINER_URL=http://localhost:9000
PORTAINER_API_KEY=

# --- Telegram Bot (for Chaguli notifications) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Local LLM endpoints (auto-configured by install.sh) ---
LLM_PRIMARY_URL=http://localhost:8080
LLM_FAST_URL=http://localhost:8081

# --- SearXNG ---
SEARXNG_URL=http://localhost:8888

# --- OpenClaw (Chaguli agent platform) ---
OPENCLAW_WORKSPACE=$HOME/.openclaw/workspace

# --- Network Schedule (PT timezone) ---
# Wifi drops daily ~11PM, comes back ~7:15AM
OFFLINE_START_HOUR=23
ONLINE_START_HOUR=7
TIMEZONE=America/Los_Angeles

# --- Mini PC (set when it arrives) ---
# Connected via ethernet subnet — stays reachable even during wifi offline
# MINIPC_IP=192.168.x.x
# MINIPC_SSH_USER=rohit

# --- GitHub Auto-Deploy ---
# Directory where cloned repos are installed
DEPLOY_DIR=/opt/deployments

# --- Optional: Grafana ---
# GRAFANA_URL=http://localhost:3000
# GRAFANA_API_KEY=

# --- Optional: Uptime Kuma ---
# UPTIME_KUMA_URL=http://localhost:3001

# --- Optional: n8n ---
# N8N_URL=http://localhost:5678
# N8N_API_KEY=
